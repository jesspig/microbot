{
  "name": "@micro-agent/client-sdk",
  "version": "0.3.0",
  "description": "MicroAgent 开发者 SDK - 客户端 API 和工具定义",
  "type": "module",
  "author": "jesspig",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jesspig/micro-agent.git",
    "directory": "sdk"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "main": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./runtime": {
      "types": "./src/runtime.ts",
      "default": "./src/runtime.ts"
    },
    "./memory": {
      "types": "./src/memory/index.ts",
      "default": "./src/memory/index.ts"
    },
    "./memory/manager": {
      "types": "./src/memory/manager.ts",
      "default": "./src/memory/manager.ts"
    },
    "./memory/classifiers/memory-classifier": {
      "types": "./src/memory/classifiers/memory-classifier.ts",
      "default": "./src/memory/classifiers/memory-classifier.ts"
    },
    "./memory/classifiers/preference-classifier": {
      "types": "./src/memory/classifiers/preference-classifier.ts",
      "default": "./src/memory/classifiers/preference-classifier.ts"
    },
    "./memory/scoring/importance-scorer": {
      "types": "./src/memory/scoring/importance-scorer.ts",
      "default": "./src/memory/scoring/importance-scorer.ts"
    },
    "./memory/handlers/preference-handler": {
      "types": "./src/memory/handlers/preference-handler.ts",
      "default": "./src/memory/handlers/preference-handler.ts"
    },
    "./memory/consolidation/summarizer": {
      "types": "./src/memory/consolidation/summarizer.ts",
      "default": "./src/memory/consolidation/summarizer.ts"
    },
    "./memory/forgetting": {
      "types": "./src/memory/forgetting/index.ts",
      "default": "./src/memory/forgetting/index.ts"
    },
    "./tool": {
      "types": "./src/tool/index.ts",
      "default": "./src/tool/index.ts"
    },
    "./define": {
      "types": "./src/define/index.ts",
      "default": "./src/define/index.ts"
    }
  },
  "files": [
    "src"
  ],
  "dependencies": {
    "@micro-agent/agent-service": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.3"
  }
}
