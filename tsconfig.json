{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@micro-agent/types": ["./agent-service/types"],
      "@micro-agent/types/*": ["./agent-service/types/*"],
      "@micro-agent/runtime": ["./agent-service/runtime"],
      "@micro-agent/runtime/*": ["./agent-service/runtime/*"],
      "@micro-agent/sdk": ["./sdk/src"],
      "@micro-agent/sdk/client": ["./sdk/src/index.ts"],
      "@micro-agent/sdk/runtime": ["./sdk/src/runtime.ts"],
      "@micro-agent/sdk/*": ["./sdk/src/*"]
    },
    "types": ["bun"]
  },
  "include": ["applications/**/*", "agent-service/**/*", "sdk/**/*"],
  "exclude": ["node_modules", "dist"]
}