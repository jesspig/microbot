{
  "name": "@micro-agent/core",
  "version": "0.2.2",
  "description": "超轻量级个人 AI 助手框架 - LLM/Agent 双向网关 + 可扩展 Agent 运行时",
  "type": "module",
  "author": "jesspig",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jesspig/micro-agent.git"
  },
  "workspaces": [
    "agent-service",
    "sdk",
    "applications/*"
  ],
  "trustedDependencies": [
    "@larksuiteoapi/node-sdk"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "bin": {
    "micro-agent": "./applications/cli/src/index.ts"
  },
  "main": "./sdk/src/index.ts",
  "exports": {
    ".": {
      "types": "./sdk/src/index.ts",
      "default": "./sdk/src/index.ts"
    },
    "./types": {
      "types": "./agent-service/types/index.ts",
      "default": "./agent-service/types/index.ts"
    },
    "./runtime": {
      "types": "./agent-service/runtime/index.ts",
      "default": "./agent-service/runtime/index.ts"
    }
  },
  "scripts": {
    "prepare": "bun link",
    "dev": "bun run applications/cli/src/index.ts start",
    "start": "bun run applications/cli/src/index.ts start",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.26.2",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@logtape/logtape": "^2.0.4",
    "@logtape/pretty": "^2.0.4",
    "@micro-agent/client-sdk": "workspace:*",
    "ai": "^6.0.106",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "marked": "^17.0.3",
    "mitt": "^3.0.1",
    "pdf-parse": "2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.3",
    "bun-types": "^1.3.10",
    "typescript": "^5.9.3"
  }
}
